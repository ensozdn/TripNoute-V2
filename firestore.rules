rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - Social features enabled
    match /users/{userId} {
      // Allow authenticated users to read any user profile (for search & suggestions)
      allow read: if request.auth != null;
      
      // Allow user to write their own data
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow user creation during registration
      allow create: if request.auth != null && request.auth.uid == userId;
    }
    
    // Places collection - Users can only access their own places
    match /places/{placeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Public places (for future social features)
      allow read: if resource.data.isPublic == true;
    }
    
    // Journeys/Trips collection - Users can only access their own journeys
    match /journeys/{journeyId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Public journeys (for future social features)
      allow read: if resource.data.isPublic == true;
    }
    
    // Follows collection - Social features
    match /follows/{followId} {
      // User can read/list follows (for queries and individual reads)
      allow read, list: if request.auth != null;
      
      // User can create a follow document where they are the follower
      allow create: if request.auth != null && 
        request.resource.data.followerId == request.auth.uid &&
        request.resource.data.followingId != null &&
        request.resource.data.createdAt != null;
      
      // User can delete a follow document where they are the follower
      allow delete: if request.auth != null && 
        resource.data.followerId == request.auth.uid;
    }
    
    // Posts collection - Explore feed content
    match /posts/{postId} {
      // Anyone authenticated can read public posts
      allow read, list: if request.auth != null && resource.data.isPublic == true;
      
      // User can create posts
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.isPublic == true;
      
      // User can update/delete their own posts
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Likes collection - Post engagement
    match /likes/{likeId} {
      // Anyone can read likes
      allow read, list: if request.auth != null;
      
      // User can create like where they are the liker
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // User can delete their own likes
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Saves collection - Bookmarks
    match /saves/{saveId} {
      // User can read/create/delete their own saves
      allow read, create, delete: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
