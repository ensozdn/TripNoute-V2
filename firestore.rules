rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - Social features enabled
    match /users/{userId} {
      // Allow authenticated users to read any user profile (for search & suggestions)
      allow read: if request.auth != null;
      
      // Allow user to write their own data
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow user creation during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // FCM Tokens subcollection - Push notifications
      match /fcmTokens/{tokenId} {
        // User can read/write their own FCM tokens
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Places collection - Users can only access their own places
    match /places/{placeId} {
      // Allow users to read their own places OR public places
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || resource.data.isPublic == true);
      
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Journeys/Trips collection - Users can only access their own journeys
    match /journeys/{journeyId} {
      // Allow users to read their own trips OR public trips
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || resource.data.isPublic == true);
        
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Follows collection - Social features
    match /follows/{followId} {
      // User can read/list follows (for queries and individual reads)
      allow read, list: if request.auth != null;
      
      // User can create a follow document where they are the follower
      allow create: if request.auth != null && 
        request.resource.data.followerId == request.auth.uid &&
        request.resource.data.followingId != null &&
        request.resource.data.createdAt != null;
      
      // User can delete a follow document where they are the follower
      allow delete: if request.auth != null && 
        resource.data.followerId == request.auth.uid;
    }
    
    // Posts collection - Explore feed content (Simplified)
    match /posts/{postId} {
      // Allow authenticated users to read and list all posts
      // Security will be handled by client-side filtering
      allow read, list: if request.auth != null;
      
      // User can create their own posts
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // User can update/delete their own posts  
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Likes collection - Post engagement
    match /likes/{likeId} {
      // Anyone can read likes
      allow read, list: if request.auth != null;
      
      // User can create like where they are the liker
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // User can delete their own likes
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Saves collection - Bookmarks
    match /saves/{saveId} {
      // User can read all saves (for checking if post is saved)
      allow read, list: if request.auth != null;
      
      // User can create their own saves
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
        
      // User can delete their own saves
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Notifications collection - User activity notifications
    match /notifications/{notificationId} {
      // User can only read their own notifications
      allow read, list: if request.auth != null && 
        resource.data.recipientId == request.auth.uid;
      
      // Only the system or authorized users can create notifications
      // In practice, only recipientId user or senderId can create
      allow create: if request.auth != null;
      
      // User can update (mark as read) their own notifications
      allow update: if request.auth != null && 
        resource.data.recipientId == request.auth.uid;
      
      // User can delete their own notifications
      allow delete: if request.auth != null && 
        resource.data.recipientId == request.auth.uid;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
