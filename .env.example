# TripNoute v2 - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# GOOGLE MAPS CONFIGURATION
# ============================================
# Get API key from Google Cloud Console
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TripNoute
NEXT_PUBLIC_APP_VERSION=2.0.0

# ============================================
# FEATURE FLAGS (for controlled rollout)
# ============================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SOCIAL_FEATURES=false
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=false

# ============================================
# DEVELOPMENT / PRODUCTION MODE
# ============================================
NODE_ENV=development

# ============================================
# FIREBASE ADMIN SDK (Server-side only)
# ============================================
# Optional: For Cloud Functions or server-side operations
# FIREBASE_ADMIN_PROJECT_ID=your_project_id
# FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email
# FIREBASE_ADMIN_PRIVATE_KEY=your_private_key

# ============================================
# SECURITY
# ============================================
# Generate a random string for session encryption
NEXTAUTH_SECRET=your_random_secret_here_change_in_production

# ============================================
# ANALYTICS (Optional)
# ============================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ============================================
# RATE LIMITING & SECURITY
# ============================================
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=900000

# ============================================
# IMAGE OPTIMIZATION
# ============================================
# Maximum file size for uploads (in bytes)
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
# Maximum number of photos per place
NEXT_PUBLIC_MAX_PHOTOS_PER_PLACE=10
